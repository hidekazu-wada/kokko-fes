---
import MySiteLayout from '../layouts/MySiteLayout.astro';
import GlobalNavigation from '../components/GlobalNavigation.astro';
import { getCurrentEventInfo, getCurrentEventConfig } from '../lib/microcms';
import type { EventInfo, EventConfig } from '../types/microcms';

let eventInfo: EventInfo[] = [];
let eventConfig: EventConfig | null = null;
let error: string | null = null;

try {
  eventConfig = await getCurrentEventConfig();
  eventInfo = await getCurrentEventInfo();
} catch (e) {
  error = 'データの取得に失敗しました';
  console.error('Error fetching event info:', e);
}
---

<MySiteLayout>
  <GlobalNavigation />
  
  <div class="event-page">
    <div class="page-header">
      <div class="container">
        <nav class="breadcrumb">
          <a href="/">ホーム</a>
          <span class="separator">＞</span>
          <span class="current">イベント情報</span>
        </nav>
        <h1 class="page-title">イベント情報</h1>
        {eventConfig && (
          <p class="page-subtitle">{eventConfig.year}年 コッコ祭り</p>
        )}
      </div>
    </div>

    <div class="container">
      {error ? (
        <div class="error-message">
          <p>{error}</p>
        </div>
      ) : eventInfo.length === 0 ? (
        <div class="no-content">
          <p>現在、イベント情報はありません。</p>
          <p>詳細が決まり次第、こちらでお知らせいたします。</p>
        </div>
      ) : (
        <div class="events-grid">
          {eventInfo.map((event) => (
            <div class="event-card">
              <h2 class="event-title">{event.title}</h2>
              <div class="event-content">
                <div class="event-description">
                  <p>{event.description}</p>
                </div>
                
                <div class="event-details">
                  <div class="detail-item">
                    <h3>スケジュール</h3>
                    <p>{event.schedule}</p>
                  </div>
                  
                  <div class="detail-item">
                    <h3>会場</h3>
                    <p>{event.venue}</p>
                  </div>
                  
                  {event.capacity && (
                    <div class="detail-item">
                      <h3>定員</h3>
                      <p>{event.capacity}</p>
                    </div>
                  )}
                  
                  {event.fee && (
                    <div class="detail-item">
                      <h3>参加費</h3>
                      <p>{event.fee}</p>
                    </div>
                  )}
                  
                  <div class="detail-item">
                    <h3>申込方法</h3>
                    <p>{event.application}</p>
                  </div>
                  
                  <div class="detail-item">
                    <h3>お問い合わせ</h3>
                    <p>{event.contact}</p>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
</MySiteLayout>

<style lang="scss">
@import '../styles/functions.scss';
@import '../styles/mixins.scss';

.event-page {
  min-height: 100vh;
  background-color: #f8f9fa;
}

.container {
  max-width: ppx(1200px);
  margin: 0 auto;
  padding: 0 spx(20px);
  
  @include tablet-up {
    padding: 0 tpx(40px);
  }
  
  @include desktop-up {
    padding: 0 ppx(40px);
  }
}

.page-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: spx(40px) 0;
  
  @include tablet-up {
    padding: tpx(60px) 0;
  }
  
  @include desktop-up {
    padding: ppx(80px) 0;
  }
}

.breadcrumb {
  font-size: spx(14px);
  margin-bottom: spx(16px);
  opacity: 0.9;
  
  @include tablet-up {
    font-size: tpx(14px);
    margin-bottom: tpx(20px);
  }
  
  @include desktop-up {
    font-size: ppx(14px);
    margin-bottom: ppx(24px);
  }

  a {
    color: white;
    text-decoration: none;
    
    &:hover {
      text-decoration: underline;
    }
  }

  .separator {
    margin: 0 spx(8px);
    
    @include tablet-up {
      margin: 0 tpx(8px);
    }
    
    @include desktop-up {
      margin: 0 ppx(8px);
    }
  }

  .current {
    opacity: 0.7;
  }
}

.page-title {
  @include zen-kaku-gothic-new-bold;
  font-size: spx(28px);
  margin: 0 0 spx(8px) 0;
  
  @include tablet-up {
    font-size: tpx(36px);
    margin: 0 0 tpx(12px) 0;
  }
  
  @include desktop-up {
    font-size: ppx(48px);
    margin: 0 0 ppx(16px) 0;
  }
}

.page-subtitle {
  font-size: spx(16px);
  margin: 0;
  opacity: 0.9;
  
  @include tablet-up {
    font-size: tpx(18px);
  }
  
  @include desktop-up {
    font-size: ppx(20px);
  }
}

.events-grid {
  padding: spx(40px) 0;
  display: grid;
  gap: spx(30px);
  
  @include tablet-up {
    padding: tpx(60px) 0;
    gap: tpx(40px);
  }
  
  @include desktop-up {
    padding: ppx(80px) 0;
    gap: ppx(50px);
  }
}

.event-card {
  background: white;
  border-radius: spx(12px);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  overflow: hidden;
  
  @include tablet-up {
    border-radius: tpx(16px);
  }
  
  @include desktop-up {
    border-radius: ppx(20px);
  }
}

.event-title {
  @include zen-kaku-gothic-new-bold;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: spx(20px) spx(24px);
  margin: 0;
  font-size: spx(20px);
  
  @include tablet-up {
    padding: tpx(24px) tpx(32px);
    font-size: tpx(24px);
  }
  
  @include desktop-up {
    padding: ppx(30px) ppx(40px);
    font-size: ppx(28px);
  }
}

.event-content {
  padding: spx(24px);
  
  @include tablet-up {
    padding: tpx(32px);
  }
  
  @include desktop-up {
    padding: ppx(40px);
  }
}

.event-description {
  margin-bottom: spx(24px);
  
  @include tablet-up {
    margin-bottom: tpx(32px);
  }
  
  @include desktop-up {
    margin-bottom: ppx(40px);
  }

  p {
    font-size: spx(16px);
    line-height: 1.6;
    color: #333;
    margin: 0;
    
    @include tablet-up {
      font-size: tpx(16px);
    }
    
    @include desktop-up {
      font-size: ppx(18px);
    }
  }
}

.event-details {
  display: grid;
  gap: spx(20px);
  
  @include tablet-up {
    grid-template-columns: repeat(2, 1fr);
    gap: tpx(24px);
  }
  
  @include desktop-up {
    gap: ppx(30px);
  }
}

.detail-item {
  border-left: spx(4px) solid #667eea;
  padding-left: spx(16px);
  
  @include tablet-up {
    border-left-width: tpx(4px);
    padding-left: tpx(20px);
  }
  
  @include desktop-up {
    border-left-width: ppx(4px);
    padding-left: ppx(24px);
  }

  h3 {
    @include zen-kaku-gothic-new-bold;
    font-size: spx(14px);
    color: #667eea;
    margin: 0 0 spx(8px) 0;
    
    @include tablet-up {
      font-size: tpx(16px);
      margin: 0 0 tpx(8px) 0;
    }
    
    @include desktop-up {
      font-size: ppx(16px);
      margin: 0 0 ppx(10px) 0;
    }
  }

  p {
    font-size: spx(14px);
    line-height: 1.5;
    color: #555;
    margin: 0;
    
    @include tablet-up {
      font-size: tpx(15px);
    }
    
    @include desktop-up {
      font-size: ppx(16px);
    }
  }
}

.error-message, .no-content {
  text-align: center;
  padding: spx(60px) spx(20px);
  color: #666;
  
  @include tablet-up {
    padding: tpx(80px) tpx(40px);
  }
  
  @include desktop-up {
    padding: ppx(100px) ppx(60px);
  }

  p {
    font-size: spx(16px);
    line-height: 1.6;
    margin-bottom: spx(16px);
    
    @include tablet-up {
      font-size: tpx(16px);
      margin-bottom: tpx(16px);
    }
    
    @include desktop-up {
      font-size: ppx(18px);
      margin-bottom: ppx(20px);
    }

    &:last-child {
      margin-bottom: 0;
    }
  }
}

.error-message {
  color: #e74c3c;
}
</style>