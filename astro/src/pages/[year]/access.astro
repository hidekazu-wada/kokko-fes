---
import MySiteLayout from '../../layouts/MySiteLayout.astro';
import GlobalNavigation from '../../components/GlobalNavigation.astro';
import { getAccessInfo, getEventConfigByYear } from '../../lib/microcms';
import type { AccessInfo, EventConfig } from '../../types/microcms';

export async function getStaticPaths() {
  // 実装時は全年度を取得する必要がありますが、現在は手動で設定
  const years = ['2024', '2025']; // 実際の運用では動的に取得
  
  return years.map(year => ({
    params: { year },
    props: { year }
  }));
}

const { year } = Astro.props;

let accessInfo: AccessInfo | null = null;
let eventConfig: EventConfig | null = null;
let error: string | null = null;

try {
  eventConfig = await getEventConfigByYear(year);
  accessInfo = await getAccessInfo(year);
} catch (e) {
  error = 'データの取得に失敗しました';
  console.error('Error fetching access info:', e);
}
---

<MySiteLayout>
  <GlobalNavigation />
  
  <div class="access-page">
    <div class="page-header">
      <div class="container">
        <nav class="breadcrumb">
          <a href="/">ホーム</a>
          <span class="separator">＞</span>
          <a href="/archive">過去の開催</a>
          <span class="separator">＞</span>
          <a href={`/${year}`}>{year}年</a>
          <span class="separator">＞</span>
          <span class="current">アクセス</span>
        </nav>
        <h1 class="page-title">{year}年 アクセス</h1>
        {eventConfig && (
          <p class="page-subtitle">{eventConfig.theme}</p>
        )}
      </div>
    </div>

    <div class="container">
      {error ? (
        <div class="error-message">
          <p>{error}</p>
        </div>
      ) : !accessInfo ? (
        <div class="no-content">
          <p>{year}年のアクセス情報はありません。</p>
        </div>
      ) : (
        <div class="access-content">
          <div class="access-grid">
            <div class="access-info">
              <div class="info-section">
                <h2 class="section-title">会場情報</h2>
                <div class="venue-info">
                  <h3 class="venue-name">{accessInfo.venue_name}</h3>
                  <div class="venue-address">
                    <h4>住所</h4>
                    <p>{accessInfo.address}</p>
                  </div>
                </div>
              </div>

              <div class="info-section">
                <h2 class="section-title">アクセス方法</h2>
                <div class="access-methods">
                  <div class="methods-content" set:html={accessInfo.access_methods.replace(/\n/g, '<br>')} />
                </div>
              </div>

              {accessInfo.parking && (
                <div class="info-section">
                  <h2 class="section-title">駐車場情報</h2>
                  <div class="parking-info">
                    <div class="parking-content" set:html={accessInfo.parking.replace(/\n/g, '<br>')} />
                  </div>
                </div>
              )}
            </div>

            {accessInfo.map_embed && (
              <div class="map-section">
                <h2 class="section-title">地図</h2>
                <div class="map-container">
                  <div class="map-embed" set:html={accessInfo.map_embed} />
                </div>
              </div>
            )}
          </div>

          <div class="access-notes">
            <div class="notes-content">
              <h3>{year}年開催時のご案内</h3>
              <ul>
                <li>この情報は{year}年開催時のものです</li>
                <li>最新の開催情報については<a href="/access">現在のアクセス情報</a>をご確認ください</li>
                <li>会場や交通機関の情報は変更されている場合があります</li>
              </ul>
            </div>
          </div>
        </div>
      )}

      <div class="navigation-links">
        <a href={`/${year}`} class="nav-link">
          ← {year}年トップに戻る
        </a>
        <a href="/archive" class="nav-link">
          過去の開催一覧 →
        </a>
      </div>
    </div>
  </div>
</MySiteLayout>

<style lang="scss">
@import '../../styles/functions.scss';
@import '../../styles/mixins.scss';

.access-page {
  min-height: 100vh;
  background-color: #f8f9fa;
}

.container {
  max-width: ppx(1200px);
  margin: 0 auto;
  padding: 0 spx(20px);
  
  @include tablet-up {
    padding: 0 tpx(40px);
  }
  
  @include desktop-up {
    padding: 0 ppx(40px);
  }
}

.page-header {
  background: linear-gradient(135deg, #43cea2 0%, #185a9d 100%);
  color: white;
  padding: spx(40px) 0;
  
  @include tablet-up {
    padding: tpx(60px) 0;
  }
  
  @include desktop-up {
    padding: ppx(80px) 0;
  }
}

.breadcrumb {
  font-size: spx(14px);
  margin-bottom: spx(16px);
  opacity: 0.9;
  
  @include tablet-up {
    font-size: tpx(14px);
    margin-bottom: tpx(20px);
  }
  
  @include desktop-up {
    font-size: ppx(14px);
    margin-bottom: ppx(24px);
  }

  a {
    color: white;
    text-decoration: none;
    
    &:hover {
      text-decoration: underline;
    }
  }

  .separator {
    margin: 0 spx(8px);
    
    @include tablet-up {
      margin: 0 tpx(8px);
    }
    
    @include desktop-up {
      margin: 0 ppx(8px);
    }
  }

  .current {
    opacity: 0.7;
  }
}

.page-title {
  @include zen-kaku-gothic-new-bold;
  font-size: spx(28px);
  margin: 0 0 spx(8px) 0;
  
  @include tablet-up {
    font-size: tpx(36px);
    margin: 0 0 tpx(12px) 0;
  }
  
  @include desktop-up {
    font-size: ppx(48px);
    margin: 0 0 ppx(16px) 0;
  }
}

.page-subtitle {
  font-size: spx(16px);
  margin: 0;
  opacity: 0.9;
  
  @include tablet-up {
    font-size: tpx(18px);
  }
  
  @include desktop-up {
    font-size: ppx(20px);
  }
}

.access-content {
  padding: spx(40px) 0;
  
  @include tablet-up {
    padding: tpx(60px) 0;
  }
  
  @include desktop-up {
    padding: ppx(80px) 0;
  }
}

.access-grid {
  display: grid;
  gap: spx(40px);
  margin-bottom: spx(50px);
  
  @include tablet-up {
    gap: tpx(50px);
    margin-bottom: tpx(60px);
  }
  
  @include desktop-up {
    grid-template-columns: 1fr 1fr;
    gap: ppx(60px);
    margin-bottom: ppx(80px);
  }
}

.access-info {
  display: grid;
  gap: spx(30px);
  
  @include tablet-up {
    gap: tpx(40px);
  }
  
  @include desktop-up {
    gap: ppx(50px);
  }
}

.info-section {
  background: white;
  border-radius: spx(12px);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  overflow: hidden;
  
  @include tablet-up {
    border-radius: tpx(16px);
  }
  
  @include desktop-up {
    border-radius: ppx(20px);
  }
}

.section-title {
  @include zen-kaku-gothic-new-bold;
  background: linear-gradient(135deg, #43cea2 0%, #185a9d 100%);
  color: white;
  padding: spx(16px) spx(24px);
  margin: 0;
  font-size: spx(18px);
  
  @include tablet-up {
    padding: tpx(20px) tpx(32px);
    font-size: tpx(20px);
  }
  
  @include desktop-up {
    padding: ppx(24px) ppx(40px);
    font-size: ppx(22px);
  }
}

.venue-info, .access-methods, .parking-info {
  padding: spx(24px);
  
  @include tablet-up {
    padding: tpx(32px);
  }
  
  @include desktop-up {
    padding: ppx(40px);
  }
}

.venue-name {
  @include zen-kaku-gothic-new-bold;
  font-size: spx(20px);
  margin: 0 0 spx(20px) 0;
  color: #333;
  
  @include tablet-up {
    font-size: tpx(24px);
    margin: 0 0 tpx(24px) 0;
  }
  
  @include desktop-up {
    font-size: ppx(28px);
    margin: 0 0 ppx(30px) 0;
  }
}

.venue-address {
  h4 {
    @include zen-kaku-gothic-new-bold;
    font-size: spx(14px);
    color: #43cea2;
    margin: 0 0 spx(8px) 0;
    
    @include tablet-up {
      font-size: tpx(16px);
      margin: 0 0 tpx(10px) 0;
    }
    
    @include desktop-up {
      font-size: ppx(16px);
      margin: 0 0 ppx(12px) 0;
    }
  }

  p {
    font-size: spx(16px);
    line-height: 1.6;
    color: #333;
    margin: 0;
    
    @include tablet-up {
      font-size: tpx(16px);
    }
    
    @include desktop-up {
      font-size: ppx(18px);
    }
  }
}

.methods-content, .parking-content {
  font-size: spx(16px);
  line-height: 1.7;
  color: #333;
  
  @include tablet-up {
    font-size: tpx(16px);
  }
  
  @include desktop-up {
    font-size: ppx(16px);
  }
}

.map-section {
  background: white;
  border-radius: spx(12px);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  overflow: hidden;
  
  @include tablet-up {
    border-radius: tpx(16px);
  }
  
  @include desktop-up {
    border-radius: ppx(20px);
  }
}

.map-container {
  padding: spx(24px);
  
  @include tablet-up {
    padding: tpx(32px);
  }
  
  @include desktop-up {
    padding: ppx(40px);
  }
}

.map-embed {
  width: 100%;
  height: spx(300px);
  border-radius: spx(8px);
  overflow: hidden;
  
  @include tablet-up {
    height: tpx(400px);
    border-radius: tpx(12px);
  }
  
  @include desktop-up {
    height: ppx(450px);
    border-radius: ppx(16px);
  }

  :global(iframe) {
    width: 100%;
    height: 100%;
    border: none;
  }
}

.access-notes {
  background: #fff8e1;
  border-radius: spx(12px);
  padding: spx(24px);
  border-left: spx(4px) solid #ffa726;
  
  @include tablet-up {
    border-radius: tpx(16px);
    padding: tpx(32px);
    border-left-width: tpx(4px);
  }
  
  @include desktop-up {
    border-radius: ppx(20px);
    padding: ppx(40px);
    border-left-width: ppx(4px);
  }
}

.notes-content {
  h3 {
    @include zen-kaku-gothic-new-bold;
    font-size: spx(18px);
    color: #f57c00;
    margin: 0 0 spx(16px) 0;
    
    @include tablet-up {
      font-size: tpx(20px);
      margin: 0 0 tpx(20px) 0;
    }
    
    @include desktop-up {
      font-size: ppx(22px);
      margin: 0 0 ppx(24px) 0;
    }
  }

  ul {
    margin: 0;
    padding-left: spx(20px);
    
    @include tablet-up {
      padding-left: tpx(24px);
    }
    
    @include desktop-up {
      padding-left: ppx(30px);
    }

    li {
      font-size: spx(14px);
      line-height: 1.6;
      color: #333;
      margin-bottom: spx(8px);
      
      @include tablet-up {
        font-size: tpx(15px);
        margin-bottom: tpx(10px);
      }
      
      @include desktop-up {
        font-size: ppx(16px);
        margin-bottom: ppx(12px);
      }

      &:last-child {
        margin-bottom: 0;
      }

      a {
        color: #43cea2;
        text-decoration: none;
        
        &:hover {
          text-decoration: underline;
        }
      }
    }
  }
}

.navigation-links {
  display: flex;
  justify-content: space-between;
  padding: spx(30px) 0;
  border-top: 1px solid #e0e0e0;
  gap: spx(16px);
  
  @include tablet-up {
    padding: tpx(40px) 0;
    gap: tpx(20px);
  }
  
  @include desktop-up {
    padding: ppx(50px) 0;
    gap: ppx(24px);
  }
}

.nav-link {
  display: inline-flex;
  align-items: center;
  padding: spx(12px) spx(20px);
  background: white;
  color: #43cea2;
  text-decoration: none;
  border-radius: spx(6px);
  border: 1px solid #43cea2;
  font-weight: 500;
  font-size: spx(14px);
  transition: all 0.2s ease;
  
  @include tablet-up {
    padding: tpx(14px) tpx(24px);
    border-radius: tpx(8px);
    font-size: tpx(15px);
  }
  
  @include desktop-up {
    padding: ppx(16px) ppx(28px);
    border-radius: ppx(10px);
    font-size: ppx(16px);
  }

  &:hover {
    background: #43cea2;
    color: white;
  }
}

.error-message, .no-content {
  text-align: center;
  padding: spx(60px) spx(20px);
  color: #666;
  
  @include tablet-up {
    padding: tpx(80px) tpx(40px);
  }
  
  @include desktop-up {
    padding: ppx(100px) ppx(60px);
  }

  p {
    font-size: spx(16px);
    line-height: 1.6;
    margin-bottom: spx(16px);
    
    @include tablet-up {
      font-size: tpx(16px);
      margin-bottom: tpx(16px);
    }
    
    @include desktop-up {
      font-size: ppx(18px);
      margin-bottom: ppx(20px);
    }

    &:last-child {
      margin-bottom: 0;
    }
  }
}

.error-message {
  color: #e74c3c;
}
</style>